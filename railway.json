{
  "$schema":"https://railway.app/railway.schema.json",
  "build":{
    "builder":"NIXPACKS",
"buildCommand":"npm ci --prefer-offline --no-audit --progress=false --ignore-scripts && npm run cacheclean && npm run build"
  },
  "deploy":{
    "startCommand":"node server.js",
    "restartPolicyType":"ON_FAILURE",
    "restartPolicyMaxRetries":10,
    "healthcheckPath":"/health",
    "healthcheckTimeout":300,
    "sleepAfterMs": 900000,
    "numReplicas":1,
    "autoDeploy":true
  }
}

# ============================================
# VHUB Platform - Environment Variables
# Railway Deployment Configuration
# ============================================

# Server Configuration
NODE_ENV=production
PORT=3000

# Supabase Configuration (Required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Features - Voz & Carreira (Required)
GEMINI_API_KEY=your_gemini_api_key
API_KEY=your_api_key_for_voz_carreira

# Legacy Firebase (Migration in Progress)
VITE_FIREBASE_API_KEY=your_firebase_key
VITE_FIREBASE_AUTH_DOMAIN=your_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Payment Integration
VITE_STRIPE_PUBLIC_KEY=pk_test_placeholder

# Optional: Daily.co for Video Calls
DAILY_CO_API_KEY=your_daily_co_key

# Optional: Error Tracking
# SENTRY_DSN=your_sentry_dsn

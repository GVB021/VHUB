{
  "name": "escola-dublagem-unified",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:voz-carreira\" \"npm run dev:ultimohub\"",
    "dev:main": "vite --port=3000 --host=0.0.0.0",
    "dev:voz-carreira": "cd voz-&-carreira---portal-de-dublagem && vite --port=3001 --host=0.0.0.0",
    "dev:ultimohub": "cd ultimohub && npm run dev",
    "build": "npm run build:main && npm run build:voz-carreira && npm run build:ultimohub",
    "build:main": "vite build",
    "build:voz-carreira": "cd voz-&-carreira---portal-de-dublagem && vite build",
    "build:ultimohub": "cd ultimohub && npm run build",
    "start": "node server.js",
    "clean": "rm -rf dist voz-&-carreira---portal-de-dublagem/dist ultimohub/dist",
    "lint": "tsc --noEmit",
    "preinstall": "npm install --ignore-scripts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@stripe/stripe-js": "^8.11.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/helmet": "^0.0.48",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.39.3",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.16.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.0",
    "ws": "^8.20.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "node server.unified.js",
    "restartPolicyType": "NEVER",
    "restartPolicyMaxRetries": 0,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300
  },
  "variables": {
    "NODE_ENV": "production",
    "NODE_VERSION": "20"
  }
}
